# Discord bot token (required)
DISCORD_TOKEN=

# Comma-separated guild IDs for slash command registration (optional, faster dev sync)
GUILD_IDS=

# Text channel ID where completed transcripts are posted (required)
TRANSCRIPT_CHANNEL_ID=

# AWS region for Bedrock (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock API key (required -- generate at https://console.aws.amazon.com/bedrock)
BEDROCK_API_KEY=

# Bedrock model ID (default: Claude 3.5 Sonnet)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Whisper model size: tiny, base, small, medium, large-v3 (default: base)
WHISPER_MODEL=base

# Seconds of audio to buffer before transcribing (default: 10)
WHISPER_CHUNK_SECONDS=10
